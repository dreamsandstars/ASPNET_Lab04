@model IEnumerable<AspNetWeek4.Mvc.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Log Explorer";
}

<div style="margin-bottom: 24px; margin-top: 10px; font-family: var(--font-display); display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 12px;">
    <div>
        <h1 class="page-title" style="font-size: 30px; font-weight: 800; color: var(--color-text-main); margin: 0; letter-spacing: -0.04em; line-height: 1.15;">Audit Log Explorer</h1>
        <p style="color: var(--color-text-muted); margin: 6px 0 0 0; font-size: 14.5px;">Real-time EF Core change tracking audit logs demonstrating tracking mechanisms and historical ledger.</p>
    </div>
    <a asp-action="Index" class="btn btn-light pressable-btn" style="padding: 10px 18px; border-radius: var(--radius-sm); font-weight: 600; text-decoration: none; font-size: 13.5px; display: inline-flex; align-items: center; gap: 8px;">
        &larr; Back to Diagnostics
    </a>
</div>

<div class="premium-card" style="font-family: var(--font-display); padding: 20px; overflow-x: auto;">
    @if (!Model.Any())
    {
        <div style="padding: 40px 0; text-align: center;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 44px; height: 44px; color: var(--color-text-muted); margin: 0 auto 12px auto; display: block;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z" />
            </svg>
            <div style="color: var(--color-text-muted); font-size: 14px; font-weight: 600;">No changes logged yet. Perform database modifications to see logs!</div>
        </div>
    }
    else
    {
        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 13.5px;">
            <thead>
                <tr style="border-bottom: 2px solid #e2e8f0; color: var(--color-text-main); font-weight: 800;">
                    <th style="padding: 12px 8px; width: 80px;">ID</th>
                    <th style="padding: 12px 8px; width: 120px;">Timestamp</th>
                    <th style="padding: 12px 8px; width: 100px;">Action</th>
                    <th style="padding: 12px 8px; width: 140px;">Entity</th>
                    <th style="padding: 12px 8px; width: 90px;">Entity ID</th>
                    <th style="padding: 12px 8px;">Changes History</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.15s;" onmouseover="this.style.background='#fafafa'" onmouseout="this.style.background='transparent'">
                        <td class="tabular-nums" style="padding: 12px 8px; color: var(--color-text-muted); font-weight: 600;">@log.Id</td>
                        <td class="tabular-nums" style="padding: 12px 8px; color: var(--color-text-muted); font-size: 12px;">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td style="padding: 12px 8px;">
                            <span class="premium-badge @(log.Action == "INSERT" ? "badge-green" : log.Action == "UPDATE" ? "badge-indigo" : log.Action == "DELETE" ? "badge-red" : "badge-amber")" style="padding: 2px 6px; font-size: 9px; font-weight: 800;">
                                @log.Action
                            </span>
                        </td>
                        <td style="padding: 12px 8px; font-weight: 700; color: var(--color-text-main);">@log.EntityName</td>
                        <td class="tabular-nums" style="padding: 12px 8px; color: var(--color-text-muted);">@log.EntityId</td>
                        <td style="padding: 12px 8px; font-family: var(--font-mono); font-size: 11.5px; color: #334155; word-break: break-all; line-height: 1.4;">
                            @log.Changes
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<style>
    .badge-red {
        background: #fef2f2;
        color: #b91c1c;
        border-color: #fca5a5;
    }
    .badge-amber {
        background: #fffbeb;
        color: #d97706;
        border-color: #fcd34d;
    }
</style>
