@using AspNetWeek4.Mvc.Models
@{
    ViewData["Title"] = "Home";
    int categoryCount = ViewBag.CategoryCount ?? 0;
    int courseCount = ViewBag.CourseCount ?? 0;
    int studentCount = ViewBag.StudentCount ?? 0;
    int enrollmentCount = ViewBag.EnrollmentCount ?? 0;
    int lowSeatsCount = ViewBag.LowSeatsCount ?? 0;
    bool isDbConnected = ViewBag.IsDbConnected ?? false;
    var recentEnrollments = ViewBag.RecentEnrollments as List<Enrollment> ?? new List<Enrollment>();
}

<div class="dashboard-viewport-wrapper">
    <!-- Dashboard Header Section -->
    <div style="margin-bottom: 20px; margin-top: 5px; display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 8px; font-family: var(--font-display);">
        <div>
            <div class="premium-badge badge-indigo" style="margin-bottom: 6px; font-size: 9.5px; padding: 2px 8px;">
                <span class="status-pulse-dot" style="width: 5px; height: 5px; border-radius: 50%; background: var(--color-success); display: inline-block;"></span>
                System Live & Connected
            </div>
            <h1 style="font-size: 26px; font-weight: 800; color: var(--color-text-main); margin: 0; letter-spacing: -0.03em; line-height: 1.1;">Dashboard Overview</h1>
            <p style="color: var(--color-text-muted); margin: 4px 0 0 0; font-size: 13.5px;">Real-time management system checking course capacity, student ledgers, and database health.</p>
        </div>
    </div>

    <!-- Metrics Bento Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 20px; font-family: var(--font-display);">
        
        <!-- Metric 1: Courses -->
        <a asp-controller="Courses" asp-action="Index" class="premium-card-wrapper" style="text-decoration: none;">
            <div class="premium-card-core" style="border-top: 3px solid #3b82f6; padding: 14px 18px;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
                    <div>
                        <span style="font-size: 10px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Courses</span>
                        <div class="tabular-nums" style="font-size: 26px; color: var(--color-text-main); margin-top: 4px; line-height: 1; font-weight: 850;">@courseCount</div>
                    </div>
                    <div style="background: #eff6ff; color: #1d4ed8; width: 30px; height: 30px; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 15px; height: 15px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                        </svg>
                    </div>
                </div>
                <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 12px; border-top: 1px solid #f4f4f5; padding-top: 8px; font-weight: 500;">
                    Across <strong style="color: var(--color-text-main); font-weight: 700;">@categoryCount</strong> categories
                </div>
            </div>
        </a>

        <!-- Metric 2: Registrations -->
        <a asp-controller="Enrollments" asp-action="History" class="premium-card-wrapper" style="text-decoration: none;">
            <div class="premium-card-core" style="border-top: 3px solid #10b981; padding: 14px 18px;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
                    <div>
                        <span style="font-size: 10px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Registrations</span>
                        <div class="tabular-nums" style="font-size: 26px; color: var(--color-text-main); margin-top: 4px; line-height: 1; font-weight: 850;">@enrollmentCount</div>
                    </div>
                    <div style="background: #e0f2fe; color: #0369a1; width: 30px; height: 30px; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 15px; height: 15px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                    </div>
                </div>
                <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 12px; border-top: 1px solid #f4f4f5; padding-top: 8px; font-weight: 500;">
                    Total <strong style="color: var(--color-text-main); font-weight: 700;">@studentCount</strong> students
                </div>
            </div>
        </a>

        <!-- Metric 3: Seat Alerts -->
        <a asp-controller="Courses" asp-action="Filter" class="premium-card-wrapper" style="text-decoration: none;">
            <div class="premium-card-core" style="border-top: 3px solid #f59e0b; padding: 14px 18px;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
                    <div>
                        <span style="font-size: 10px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Seat Alerts</span>
                        <div class="tabular-nums" style="font-size: 26px; color: @(lowSeatsCount > 0 ? "var(--color-danger)" : "var(--color-success)"); margin-top: 4px; line-height: 1; font-weight: 850;">
                            @(lowSeatsCount > 0 ? $"{lowSeatsCount} Low" : "Clear")
                        </div>
                    </div>
                    <div style="background: @(lowSeatsCount > 0 ? "#fef2f2" : "#ecfdf5"); color: @(lowSeatsCount > 0 ? "var(--color-danger)" : "var(--color-success)"); width: 30px; height: 30px; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                        @if (lowSeatsCount > 0)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 15px; height: 15px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 15px; height: 15px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        }
                    </div>
                </div>
                <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 12px; border-top: 1px solid #f4f4f5; padding-top: 8px; font-weight: 500;">
                    Limit set to &le; <strong style="color: var(--color-text-main); font-weight: 700;">3</strong> seats
                </div>
            </div>
        </a>

        <!-- Metric 4: DB Connection -->
        <a asp-controller="DataHealth" asp-action="Index" class="premium-card-wrapper" style="text-decoration: none;">
            <div class="premium-card-core" style="border-top: 3px solid #8b5cf6; padding: 14px 18px;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
                    <div>
                        <span style="font-size: 10px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Engine Status</span>
                        <div style="font-size: 20px; font-weight: 850; color: var(--color-text-main); margin-top: 8px; line-height: 1;">SQLite</div>
                    </div>
                    <div style="background: #faf5ff; color: #7c3aed; width: 30px; height: 30px; border-radius: 6px; display: flex; align-items: center; justify-content: center;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 15px; height: 15px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" />
                        </svg>
                    </div>
                </div>
                <div style="font-size: 11px; color: var(--color-text-muted); margin-top: 12px; border-top: 1px solid #f4f4f5; padding-top: 8px; display: flex; align-items: center; justify-content: space-between; font-weight: 500;">
                    <span>Connection</span>
                    <span class="premium-badge @(isDbConnected ? "badge-green" : "badge-amber")" style="padding: 2px 6px; font-size: 8.5px;">
                        ONLINE
                    </span>
                </div>
            </div>
        </a>

    </div>

    <!-- Lower Sections: Quick Actions & Recent Transactions (Flex Fill & No Scroll) -->
    <div class="dashboard-lower-grid" style="font-family: var(--font-display);">
        
        <!-- Quick Operations -->
        <div class="premium-card-wrapper" style="height: 100%;">
            <div class="premium-card-core" style="padding: 16px 20px; height: 100%; justify-content: flex-start;">
                <h3 style="font-size: 15px; font-weight: 800; color: var(--color-text-main); margin: 0 0 12px 0; border-bottom: 1px solid #f4f4f5; padding-bottom: 8px; letter-spacing: -0.02em;">Quick Operations</h3>
                
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    <a asp-controller="Courses" asp-action="Index" class="quick-operation-row" style="padding: 10px 12px;">
                        <div style="background: #eff6ff; color: #1d4ed8; width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
                            </svg>
                        </div>
                        <div>
                            <div style="font-size: 13.5px; font-weight: 700; color: var(--color-text-main);">Browse Courses</div>
                            <div style="font-size: 11px; color: var(--color-text-muted); margin-top: 1px;">View active seats and details</div>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="chevron-arrow" style="width: 10px; height: 10px; right: 12px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>

                    <a asp-controller="Enrollments" asp-action="Create" class="quick-operation-row" style="padding: 10px 12px;">
                        <div style="background: #ecfdf5; color: #047857; width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                            </svg>
                        </div>
                        <div>
                            <div style="font-size: 13.5px; font-weight: 700; color: var(--color-text-main);">Register Student</div>
                            <div style="font-size: 11px; color: var(--color-text-muted); margin-top: 1px;">Create transaction-safe bookings</div>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="chevron-arrow" style="width: 10px; height: 10px; right: 12px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>

                    <a asp-controller="DataHealth" asp-action="Index" class="quick-operation-row" style="padding: 10px 12px;">
                        <div style="background: #faf5ff; color: #7c3aed; width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 14px; height: 14px;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" />
                            </svg>
                        </div>
                        <div>
                            <div style="font-size: 13.5px; font-weight: 700; color: var(--color-text-main);">EF Core Diagnostics</div>
                            <div style="font-size: 11px; color: var(--color-text-muted); margin-top: 1px;">Database health and migrations</div>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="chevron-arrow" style="width: 10px; height: 10px; right: 12px;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Recent Activity Log -->
        <div class="premium-card-wrapper" style="height: 100%;">
            <div class="premium-card-core" style="padding: 16px 20px; height: 100%; justify-content: flex-start;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; border-bottom: 1px solid #f4f4f5; padding-bottom: 8px;">
                    <h3 style="font-size: 15px; font-weight: 800; color: var(--color-text-main); margin: 0; letter-spacing: -0.02em;">Recent Registrations</h3>
                    <a asp-controller="Enrollments" asp-action="History" style="font-size: 12px; color: var(--color-accent); text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 4px;">
                        View History &rarr;
                    </a>
                </div>

                @if (!recentEnrollments.Any())
                {
                    <div style="padding: 30px 0; text-align: center; margin: auto 0;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 38px; height: 38px; color: var(--color-text-muted); margin: 0 auto 8px auto; display: block;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18V6c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125V7.5Z" />
                        </svg>
                        <div style="color: var(--color-text-muted); font-size: 12.5px; font-weight: 500;">No registrations logged yet</div>
                    </div>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        @foreach (var enrollment in recentEnrollments.Take(2))
                        {
                            <div class="activity-log-row" style="padding: 10px 14px;">
                                <div style="display: flex; flex-direction: column; gap: 2px; flex-grow: 1;">
                                    <div style="font-weight: 700; font-size: 13.5px; color: var(--color-text-main); line-height: 1.2;">@enrollment.Student?.Name</div>
                                    <div style="font-size: 11px; color: var(--color-text-muted);">
                                        @enrollment.Student?.Email &bull; @enrollment.CreatedAt.ToString("MM/dd HH:mm")
                                    </div>
                                    <div style="display: flex; gap: 4px; flex-wrap: wrap; margin-top: 4px;">
                                        @foreach (var detail in enrollment.EnrollmentDetails)
                                        {
                                            <span class="premium-badge badge-indigo" style="font-size: 9px; padding: 1px 5px;">
                                                @detail.Course?.Name (@detail.Quantity)
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div class="tabular-nums" style="font-size: 13.5px; color: var(--color-text-main); border: 1px solid #e2e8f0; padding: 4px 8px; border-radius: 6px; background: #fafafa; flex-shrink: 0; font-weight: 700; margin-left: 12px;">
                                    @enrollment.TotalAmount.ToString("N0") <span style="font-size: 10px; font-weight: 500; color: var(--color-text-muted);">VND</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</div>

<style>
    /* Viewport constraint styling */
    @@media (min-width: 901px) {
        .dashboard-viewport-wrapper {
            height: calc(100vh - 120px);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .dashboard-lower-grid {
            flex: 1;
            min-height: 0;
            display: grid;
            grid-template-columns: 1fr 1.4fr;
            gap: 16px;
            overflow: hidden;
            margin-bottom: 5px;
        }
    }
    @@media (max-width: 900px) {
        .dashboard-lower-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>
