@model IEnumerable<AspNetWeek4.Mvc.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollment History";
}

<div style="margin-bottom: 32px; margin-top: 10px; font-family: var(--font-display);">
    <h1 class="page-title" style="font-size: 34px; font-weight: 800; color: var(--color-text-main); margin: 0; letter-spacing: -0.04em; line-height: 1.15;">Enrollment Ledger</h1>
    <p style="color: var(--color-text-muted); margin: 6px 0 0 0; font-size: 14.5px;">Historical log of verified registrations (queried efficiently using AsNoTracking + Include joins)</p>
</div>

<div class="minimalist-table-wrapper" style="font-family: var(--font-display);">
    <table class="minimalist-table">
        <thead>
            <tr style="font-size: 11.5px; letter-spacing: 0.05em; text-transform: uppercase;">
                <th style="padding: 16px 20px;">TXN ID</th>
                <th style="padding: 16px 20px;">Timestamp</th>
                <th style="padding: 16px 20px;">Student Account</th>
                <th style="padding: 16px 20px;">Course Offerings</th>
                <th style="padding: 16px 20px; text-align: center;">Seats</th>
                <th style="padding: 16px 20px; text-align: right;">Total Amount</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" style="padding: 48px; text-align: center; color: var(--color-text-muted); font-size: 14.5px;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 40px; height: 40px; margin: 0 auto 12px auto; color: #cbd5e1; display: block;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                        </svg>
                        No enrollment transactions recorded yet.
                    </td>
                </tr>
            }
            else
            {
                foreach (var enroll in Model)
                {
                    <tr>
                        <td>
                            <span style="font-family: var(--font-mono); font-weight: 700; color: var(--color-accent); font-size: 13px;">
                                #ENR-@enroll.Id.ToString("D4")
                            </span>
                        </td>
                        <td style="color: var(--color-text-muted); font-size: 13.5px;">
                            @enroll.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                        </td>
                        <td>
                            <div style="font-weight: 700; color: var(--color-text-main);">@enroll.Student?.Name</div>
                            <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 2px;">@enroll.Student?.Email</div>
                        </td>
                        <td>
                            @foreach (var detail in enroll.EnrollmentDetails)
                            {
                                <div style="font-weight: 600; color: var(--color-text-main);">
                                    @detail.Course?.Name
                                </div>
                                <div style="font-size: 11.5px; color: var(--color-text-muted); margin-top: 1px;">
                                    Unit Price: @detail.UnitPrice.ToString("N0") VND
                                </div>
                            }
                        </td>
                        <td class="tabular-nums" style="text-align: center; color: var(--color-text-main);">
                            @enroll.EnrollmentDetails.Sum(d => d.Quantity)
                        </td>
                        <td class="tabular-nums" style="text-align: right; color: var(--color-text-main); font-size: 15px;">
                            @enroll.TotalAmount.ToString("N0") <span style="font-size: 11px; font-weight: 500; color: var(--color-text-muted);">VND</span>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
