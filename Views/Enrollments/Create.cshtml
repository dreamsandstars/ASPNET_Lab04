@model AspNetWeek4.Mvc.ViewModels.EnrollmentCreateViewModel

@{
    ViewData["Title"] = "Course Enrollment";
    var courses = ViewBag.Courses as IEnumerable<AspNetWeek4.Mvc.ViewModels.CourseListItemViewModel> ?? new List<AspNetWeek4.Mvc.ViewModels.CourseListItemViewModel>();
}

<div style="max-width: 460px; margin: 20px auto; font-family: var(--font-display);">
    <h1 style="font-size: 26px; font-weight: 800; color: var(--color-text-main); margin-bottom: 4px; text-align: center; letter-spacing: -0.03em;">Course Enrollment</h1>
    <p style="color: var(--color-text-muted); text-align: center; margin-bottom: 24px; font-size: 13.5px; line-height: 1.5;">Register student details to request class enrollment (processed safely via db transactions)</p>

    <div class="premium-card" style="padding: 28px;">
        <form asp-controller="Enrollments" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div asp-validation-summary="ModelOnly" style="background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; border-radius: var(--radius-sm); padding: 10px 14px; font-size: 13px; margin-bottom: 18px; font-weight: 500;"></div>
            }

            <div style="margin-bottom: 16px;">
                <label asp-for="StudentName" style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Full Name</label>
                <input asp-for="StudentName" placeholder="e.g. John Doe" class="premium-input" />
                <span asp-validation-for="StudentName" style="color: var(--color-danger); font-size: 12px; margin-top: 4px; display: block; font-weight: 500;"></span>
            </div>

            <div style="margin-bottom: 16px;">
                <label asp-for="StudentEmail" style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Email Address</label>
                <input asp-for="StudentEmail" placeholder="e.g. john.doe@example.com" class="premium-input" />
                <span asp-validation-for="StudentEmail" style="color: var(--color-danger); font-size: 12px; margin-top: 4px; display: block; font-weight: 500;"></span>
            </div>

            <div style="margin-bottom: 16px;">
                <label asp-for="CourseId" style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Select Course</label>
                <select asp-for="CourseId" class="premium-input" style="padding: 0 8px;">
                    <option value="">-- Select Course --</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.Id">
                            @c.Name (@c.Price.ToString("N0") VND) - Remaining: @c.AvailableSeats seats
                        </option>
                    }
                </select>
                <span asp-validation-for="CourseId" style="color: var(--color-danger); font-size: 12px; margin-top: 4px; display: block; font-weight: 500;"></span>
            </div>

            <div style="margin-bottom: 24px;">
                <label asp-for="Quantity" style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Number of Seats (Quantity)</label>
                <input asp-for="Quantity" type="number" min="1" max="10" class="premium-input" />
                <span asp-validation-for="Quantity" style="color: var(--color-danger); font-size: 12px; margin-top: 4px; display: block; font-weight: 500;"></span>
            </div>

            <button type="submit" class="btn pressable-btn" style="width: 100%; height: 40px; background: var(--color-accent); color: white; border: none; font-size: 13.5px; font-weight: 600; border-radius: var(--radius-sm); cursor: pointer;">
                Confirm Enrollment
            </button>
        </form>
    </div>
</div>
