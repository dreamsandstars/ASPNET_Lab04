@model IEnumerable<AspNetWeek4.Mvc.ViewModels.CourseListItemViewModel>

@{
    ViewData["Title"] = "Filter Courses";
    var categories = ViewBag.Categories as IEnumerable<AspNetWeek4.Mvc.ViewModels.CourseCategoryListItemViewModel> ?? new List<AspNetWeek4.Mvc.ViewModels.CourseCategoryListItemViewModel>();
    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
}

<div style="margin-bottom: 24px; margin-top: 10px; font-family: var(--font-display);">
    <h1 class="page-title" style="font-size: 24px; font-weight: 800; color: var(--color-text-main); margin: 0; letter-spacing: -0.03em;">Advanced Course Search</h1>
    <p style="color: var(--color-text-muted); margin: 4px 0 0 0; font-size: 13.5px;">Filter training courses by category and price point (using optimized read tracking)</p>
</div>

<div class="premium-card" style="padding: 20px; margin-bottom: 24px; font-family: var(--font-display);">
    <form method="get" asp-controller="Courses" asp-action="Filter" class="filter-grid-layout" style="display: grid; grid-template-columns: 1.2fr 1fr 1fr auto; gap: 14px; align-items: flex-end;">
        <div>
            <label style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Course Category</label>
            <select name="categoryId" class="premium-input" style="height: 38px;">
                <option value="">-- All Categories --</option>
                @foreach (var cat in categories)
                {
                    if (selectedCategoryId.HasValue && selectedCategoryId.Value == cat.Id)
                    {
                        <option value="@cat.Id" selected>@cat.Name</option>
                    }
                    else
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            </select>
        </div>

        <div>
            <label style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Min Price (VND)</label>
            <input type="number" name="minPrice" value="@minPrice" placeholder="e.g. 500,000" class="premium-input" style="height: 38px;" />
        </div>

        <div>
            <label style="display: block; font-size: 12px; font-weight: 700; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Max Price (VND)</label>
            <input type="number" name="maxPrice" value="@maxPrice" placeholder="e.g. 4,000,000" class="premium-input" style="height: 38px;" />
        </div>

        <div style="display: flex; gap: 8px;">
            <button type="submit" class="btn pressable-btn" style="height: 38px; background: var(--color-accent); border-radius: var(--radius-sm); font-weight: 600; font-size: 13px; padding: 0 20px; border: none;">
                Filter
            </button>
            <a asp-controller="Courses" asp-action="Filter" class="btn btn-light pressable-btn" style="height: 38px; display: inline-flex; align-items: center; justify-content: center; border-radius: var(--radius-sm); font-weight: 600; text-decoration: none; font-size: 13px; padding: 0 20px;">
                Clear
            </a>
        </div>
    </form>
</div>

<div class="results-container" style="font-family: var(--font-display);">
    @if (!Model.Any())
    {
        <div style="background: #ffffff; border: 2px dashed #cbd5e1; border-radius: var(--radius-lg); padding: 48px 32px; text-align: center; color: var(--color-text-muted);">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 44px; height: 44px; margin: 0 auto 12px auto; color: #cbd5e1;">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.602 10.602Z" />
            </svg>
            <p style="font-size: 15px; font-weight: 700; color: var(--color-text-main); margin: 0 0 4px 0;">No matching courses found</p>
            <p style="font-size: 13px; margin: 0;">Try adjusting your category selection or pricing bounds.</p>
        </div>
    }
    else
    {
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
            @foreach (var course in Model)
            {
                <div class="premium-card" style="display: flex; flex-direction: column; justify-content: space-between; position: relative;">
                    <div>
                        <span class="premium-badge badge-indigo" style="margin-bottom: 12px;">
                            @course.CategoryName
                        </span>
                        
                        <h3 style="font-size: 18px; font-weight: 800; color: var(--color-text-main); margin: 0 0 8px 0; letter-spacing: -0.02em; line-height: 1.3;">
                            @if (!string.IsNullOrEmpty(course.CourseCode))
                            {
                                <span style="color: var(--color-accent); font-family: var(--font-mono); font-size: 15px; margin-right: 4px; font-weight: 700;">[@course.CourseCode]</span>
                            }
                            @course.Name
                        </h3>
                        
                        <div class="tabular-nums" style="font-size: 20px; color: var(--color-text-main); margin-top: 10px; letter-spacing: -0.03em;">
                            @course.Price.ToString("N0") <span style="font-size: 13px; font-weight: 500; color: var(--color-text-muted);">VND</span>
                        </div>
                    </div>
                    
                    <div style="margin-top: 20px; padding-top: 14px; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; font-size: 13.5px;">
                        <span style="color: var(--color-text-muted);">
                            Seats left: <strong class="tabular-nums" style="color: @(course.IsLowSeats ? "var(--color-danger)" : "var(--color-success)"); font-size: 14.5px;">@course.AvailableSeats</strong>
                        </span>
                        <a asp-action="Detail" asp-route-id="@course.Id" style="color: var(--color-accent); font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px;">
                            Details &rarr;
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    @@media (max-width: 768px) {
        .filter-grid-layout {
            grid-template-columns: 1fr !important;
        }
    }
</style>
