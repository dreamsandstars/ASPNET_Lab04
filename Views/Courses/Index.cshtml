@model IEnumerable<AspNetWeek4.Mvc.ViewModels.CourseListItemViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; margin-top: 10px; font-family: var(--font-display);">
    <div>
        <h1 class="page-title" style="font-size: 34px; font-weight: 800; color: var(--color-text-main); margin: 0; letter-spacing: -0.04em;">Available Courses</h1>
        <p style="color: var(--color-text-muted); margin: 6px 0 0 0; font-size: 14.5px;">List of training courses currently open for registration</p>
    </div>
    <a asp-controller="Courses" asp-action="Filter" class="btn pressable-btn" style="background: var(--color-accent); color: white; padding: 10px 18px; border-radius: var(--radius-sm); font-weight: 600; text-decoration: none; font-size: 13.5px; display: inline-flex; align-items: center; gap: 8px;">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 14px; height: 14px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.602 10.602Z" />
        </svg>
        Advanced Search
    </a>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; font-family: var(--font-display);">
    @foreach (var course in Model)
    {
        <div class="premium-card" style="display: flex; flex-direction: column; justify-content: space-between; position: relative;">
            
            @if (course.IsLowSeats)
            {
                <div class="premium-badge badge-amber" style="position: absolute; top: 20px; right: 20px; font-size: 10px; font-weight: 700;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 11px; height: 11px;">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    Low Seats
                </div>
            }

            <div>
                <span class="premium-badge badge-indigo" style="margin-bottom: 14px;">
                    @course.CategoryName
                </span>
                
                <h3 style="font-size: 20px; font-weight: 800; color: var(--color-text-main); margin: 0 0 8px 0; letter-spacing: -0.02em; line-height: 1.3;">
                    @if (!string.IsNullOrEmpty(course.CourseCode))
                    {
                        <span style="color: var(--color-accent); font-family: var(--font-mono); font-size: 17px; margin-right: 4px; font-weight: 700;">[@course.CourseCode]</span>
                    }
                    @course.Name
                </h3>

                <div class="tabular-nums" style="font-size: 22px; color: var(--color-text-main); margin-top: 12px; letter-spacing: -0.03em;">
                    @course.Price.ToString("N0") <span style="font-size: 13.5px; font-weight: 500; color: var(--color-text-muted); margin-left: 2px;">VND</span>
                </div>
            </div>

            <div style="margin-top: 24px; padding-top: 16px; border-top: 1px solid #f1f5f9; display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-size: 13.5px; color: var(--color-text-muted);">
                        Remaining: <strong class="tabular-nums" style="color: @(course.IsLowSeats ? "var(--color-danger)" : "var(--color-success)"); font-size: 15px;">@course.AvailableSeats</strong> seats
                    </span>
                    
                    <a asp-action="Detail" asp-route-id="@course.Id" style="color: var(--color-accent); font-size: 13.5px; font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px; transition: color 0.15s;">
                        Details &rarr;
                    </a>
                </div>

                @if (course.AvailableSeats > 0)
                {
                    <button data-id="@course.Id" data-name="@course.Name" data-price="@course.Price" class="add-to-cart-btn btn pressable-btn" style="width: 100%; background: #0f172a; color: white; padding: 8px; border-radius: 6px; font-size: 12.5px; font-weight: 700; border: none; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.15s;">
                        🛒 Add to Cart
                    </button>
                }
                else
                {
                    <button disabled style="width: 100%; background: #e2e8f0; color: #94a3b8; padding: 8px; border-radius: 6px; font-size: 12.5px; font-weight: 700; border: none; cursor: not-allowed; display: inline-flex; align-items: center; justify-content: center; gap: 6px;">
                        ❌ Fully Booked
                    </button>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".add-to-cart-btn").forEach(button => {
            button.addEventListener("click", function () {
                const id = parseInt(this.getAttribute("data-id"));
                const name = this.getAttribute("data-name");
                const price = parseFloat(this.getAttribute("data-price"));

                let cart = JSON.parse(localStorage.getItem("tc_cart") || "[]");
                const existing = cart.find(item => item.id === id);

                if (existing) {
                    existing.quantity += 1;
                } else {
                    cart.push({ id, name, price, quantity: 1 });
                }

                localStorage.setItem("tc_cart", JSON.stringify(cart));
                
                if (typeof updateGlobalCartBadge === "function") {
                    updateGlobalCartBadge();
                }

                const originalText = this.innerHTML;
                this.innerHTML = "✓ Added!";
                this.style.background = "var(--color-success)";
                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.style.background = "#0f172a";
                }, 1000);
            });
        });
    </script>
}
