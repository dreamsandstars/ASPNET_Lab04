@model AspNetWeek4.Mvc.Models.Course

@{
    ViewData["Title"] = Model.Name;
}

<div style="margin-bottom: 24px; margin-top: 10px; max-width: 680px; margin-left: auto; margin-right: auto; font-family: var(--font-display);">
    <a asp-action="Index" class="tabular-nums" style="text-decoration: none; color: var(--color-text-muted); font-size: 13.5px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px; transition: color 0.15s;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-text-muted)'">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 14px; height: 14px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Courses
    </a>
</div>

<div class="premium-card" style="max-width: 680px; margin: 0 auto; padding: 36px; font-family: var(--font-display);">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; gap: 20px; flex-wrap: wrap;">
        <div>
            <span class="premium-badge badge-indigo" style="margin-bottom: 12px;">
                @Model.CourseCategory?.Name
            </span>
            <h1 style="font-size: 30px; font-weight: 800; color: var(--color-text-main); margin: 0 0 8px 0; letter-spacing: -0.04em; line-height: 1.2;">
                @Model.Name
            </h1>
            <p style="color: var(--color-text-muted); font-size: 13.5px; margin: 0; display: flex; align-items: center; gap: 6px;">
                Course Code: 
                <span style="font-family: var(--font-mono); font-weight: 700; color: var(--color-accent); background: #faf5ff; border: 1px solid #f3e8ff; padding: 2px 6px; border-radius: 4px; font-size: 12px;">
                    @(string.IsNullOrEmpty(Model.CourseCode) ? "N/A" : Model.CourseCode)
                </span>
            </p>
        </div>
        
        <div style="text-align: right; min-width: 150px;">
            <div class="tabular-nums" style="font-size: 28px; color: var(--color-text-main); line-height: 1; letter-spacing: -0.03em;">
                @Model.Price.ToString("N0") <span style="font-size: 14px; font-weight: 500; color: var(--color-text-muted); margin-left: 2px;">VND</span>
            </div>
            <span style="font-size: 12px; color: var(--color-text-muted); font-weight: 500; display: block; margin-top: 6px;">Full Tuition Fee</span>
        </div>
    </div>

    <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: var(--radius-md); padding: 20px; margin-bottom: 30px; display: grid; grid-template-columns: 1fr 1fr; text-align: center; gap: 16px;">
        <div style="border-right: 1px solid #e2e8f0; padding: 4px 0;">
            <div style="font-size: 12.5px; color: var(--color-text-muted); margin-bottom: 4px; font-weight: 500;">Available Seats</div>
            <div class="tabular-nums" style="font-size: 22px; color: @(Model.AvailableSeats <= 3 ? "var(--color-danger)" : "var(--color-success)");">
                @Model.AvailableSeats <span style="font-size: 13.5px; font-weight: 600; color: var(--color-text-muted);">seats left</span>
            </div>
        </div>
        <div style="padding: 4px 0;">
            <div style="font-size: 12.5px; color: var(--color-text-muted); margin-bottom: 4px; font-weight: 500;">Enrollment Status</div>
            <div style="font-size: 20px; font-weight: 800; color: @(Model.AvailableSeats > 0 ? "var(--color-success)" : "var(--color-danger)");">
                @(Model.AvailableSeats > 0 ? "Active / Open" : "Closed / Full")
            </div>
        </div>
    </div>

    <div style="border-top: 1px solid #f1f5f9; padding-top: 24px;">
        <h3 style="font-size: 16px; font-weight: 800; color: var(--color-text-main); margin-bottom: 10px; letter-spacing: -0.01em;">Course Description</h3>
        <p style="color: #475569; line-height: 1.65; font-size: 14px; margin: 0;">
            This course provides foundational knowledge and professional practical skills. Students learn from industry experts, work directly on real-world projects, gain hands-on experience, and receive career guidance upon course completion.
        </p>
    </div>

    <div style="margin-top: 36px; text-align: center; padding-top: 24px; border-top: 1px solid #f1f5f9;">
        @if (Model.AvailableSeats > 0)
        {
            <a asp-controller="Enrollments" asp-action="Create" asp-route-courseId="@Model.Id" class="btn pressable-btn" style="background: var(--color-accent); color: white; padding: 12px 36px; border-radius: var(--radius-sm); font-weight: 600; text-decoration: none; display: inline-block; font-size: 14px; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.15);">
                Enroll in this Course
            </a>
        }
        else
        {
            <button class="btn" disabled style="background: #f1f5f9; color: #94a3b8; padding: 12px 36px; border-radius: var(--radius-sm); font-weight: 600; border: 1px solid #cbd5e1; cursor: not-allowed; font-size: 14px; box-shadow: none;">
                Class is Full
            </button>
        }
    </div>
</div>
